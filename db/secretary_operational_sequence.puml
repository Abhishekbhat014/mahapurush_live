@startuml Secretary_Operational_Sequence

!theme vibrant
skinparam backgroundColor #FFFFFF
skinparam sequence {
    ArrowColor #884EA0
    ActorBorderColor #884EA0
    LifeLineBorderColor #884EA0
    LifeLineBackgroundColor #F5EEF8
    ParticipantBorderColor #884EA0
    ParticipantBackgroundColor #E8DAEF
    ParticipantFontName 'Verdana'
    ParticipantFontSize 14
    ActorBackgroundColor #E8DAEF
    ActorFontName 'Verdana'
    ActorFontSize 14
}

header Mahapurush Mandir Operations
footer Page %page% of %lastpage%
title Secretary Operational & Content Management (Sequence Diagram)

actor "Secretary" as Secretary
boundary "Admin Console" as Console
control "Operations Controller" as Controller
database "System Database" as DB
entity "Storage Service" as Storage

== Operational Authentication ==

Secretary -> Console : Login to Operational Dashboard
activate Console
Console -> Controller : Validate Secretary Session
activate Controller
Controller -> DB : CHECK role: SECRETARY
activate DB
DB --> Controller : Credentials OK | Role: Secretary
deactivate DB
Controller --> Console : Unlock Operational Tools
deactivate Controller
Console --> Secretary : Access Granted
deactivate Console

== Ritual Management (Pooja Requests) ==

group Pooja Orchestration
    Secretary -> Console : List "Pending Rituals"
    activate Console
    Console -> Controller : GET /admin/pooja/list
    activate Controller
    Controller -> DB : SELECT * FROM pooja WHERE status='pending'
    activate DB
    DB --> Controller : Booking Dataset
    deactivate DB
    Controller --> Console : Render Ritual Management Table
    deactivate Controller
    
    Secretary -> Console : "Allocate Priest & Slot" (Booking #B-101)
    activate Console
    Console -> Controller : PUT /admin/pooja/update
    activate Controller
    Controller -> DB : UPDATE pooja SET status='completed'
    activate DB
    DB --> Controller : DONE
    deactivate DB
    Controller --> Console : Notification: Slot Finalized
    deactivate Controller
end

== Community Engagement (Event Coordination) ==

group Event Management Flow
    Secretary -> Console : "Create New Temple Event"
    activate Console
    Console -> Controller : POST /admin/events/new
    activate Controller
    Controller -> DB : INSERT INTO events (name, conduct_on, status)
    activate DB
    DB --> Controller : EventID: E-505
    deactivate DB
    Controller --> Console : Event Published Successfully
    deactivate Controller
    
    opt Update Participant List
        Secretary -> Console : View "Event Registrations"
        Console -> Controller : Fetch Participants
        Controller -> DB : SELECT * FROM event_participants
        DB --> Controller : List of Devotees
        Controller --> Console : Render Attendance Sheet
    end
end

== Content Administration (Gallery) ==

group Digital Asset Management
    Secretary -> Console : "Refresh Gallery Assets"
    activate Console
    Console -> Controller : Upload Image/Video
    activate Controller
    Controller -> Storage : Commit Binary Content
    activate Storage
    Storage --> Controller : Asset URL: /gallery/ritual_01.jpg
    deactivate Storage
    Controller -> DB : INSERT INTO gallery (path, category)
    activate DB
    DB --> Controller : Metadata Saved
    deactivate DB
    Controller --> Console : "Media Live on Website"
    deactivate Controller
end

== Approval Authority (Contributions) ==

group Contribution Oversight
    Secretary -> Console : Review "Material Contributions"
    activate Console
    Console -> Controller : GET /contributions/pending
    activate Controller
    Controller -> DB : SELECT FROM contributions
    activate DB
    DB --> Controller : Contribution Details
    deactivate DB
    Controller --> Console : Display Logic
    deactivate Controller
    
    alt Contribution Approved
        Secretary -> Console : "Approve & Log for Treasurer"
        Console -> Controller : Set status: 'approved'
        activate Controller
        Controller -> DB : UPDATE status
        DB --> Controller : SUCCESS
        Controller --> Console : Item Added to Asset Ledger
        deactivate Controller
    else Rejected
        Secretary -> Console : "Reject (Non-compliant)"
        Console -> Controller : DELETE / Set status: 'rejected'
    end
end

@enduml
